{
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": false,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty",
      "kitty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },
  "custom/power": {
    "format": "пҖ‘",
    "on-click": "wlogout",
    "tooltip-format": "Power Menu"
  },
  "clock": {
    "format": "{:%H:%M %a}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "battery": {
    "states": {
      "warning": 35,
      "critical": 20
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "оәЎ  {capacity}%",
    "format-plugged": "пҮҰ  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": [
      "пү„",
      "пүғ",
      "пүӮ",
      "пүҒ",
      "пүҖ"
    ]
  },
  "cpu": {
    "format": "пӢӣ {usage}%",
    "on-click": "~/.config/dotfiles/scripts/applications.sh run terminal --class dotfiles-floating -e htop",
    "states": {
      "normal": 0,
      "warning": 50,
      "critical": 75
    }
  },
  "memory": {
    "format": "оҝ… {}%",
    "on-click": "~/.config/dotfiles/scripts/applications.sh run terminal --class dotfiles-floating -e htop",
    "states": {
      "normal": 0,
      "warning": 50,
      "critical": 75
    }
  },
  "disk": {
    "interval": 10,
    "format": "пӮ  {percentage_used}%",
    "path": "/",
    "on-click": "~/.config/dotfiles/scripts/applications.sh run terminal --class dotfiles-floating -e htop",
    "states": {
      "normal": 0,
      "warning": 50,
      "critical": 75
    }
  },
  "custom/wallpaper": {
    "format": "пҖҫ",
    "on-click": "waypaper",
    "tooltip-format": "Select a wallpaper"
  },
  "custom/rofi": {
    "format": "Apps",
    "on-click": "rofi -show drun -replace",
    "tooltip-format": "Open the application launcher"
  },
  "custom/chromium": {
    "format": "пүЁ",
    "on-click": "chromium",
    "tooltip-format": "Open Chromium"
  },
  "custom/brave": {
    "format": "оҳј",
    "on-click": "brave",
    "tooltip-format": "Open Brave"
  },
  "custom/firefox": {
    "format": "пү©",
    "on-click": "firefox",
    "tooltip-format": "Open Firefox"
  },
  "custom/filemanager": {
    "format": "пҒј",
    "on-click": "~/.config/dotfiles/scripts/applications.sh run filemanager",
    "tooltip-format": "Open filemanager"
  },
  
  "custom/notification": {
    "tooltip": true,
    "format": "<span size='16pt'>{icon}</span>",
    "tooltip-format": "Notification center",
    "format-icons": {
      "notification": "уұ…«",
      "none": "у°Ӯң",
      "dnd-notification": "у°Ӯ ",
      "dnd-none": "у°Ә“",
      "inhibited-notification": "у°Ӯӣ",
      "inhibited-none": "у°Ә‘",
      "dnd-inhibited-notification": "у°Ӯӣ",
      "dnd-inhibited-none": "у°Ә‘"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "о»Ё",
    "format-bluetooth": "{icon} пҠ” {volume}% {format_source}",
    "format-bluetooth-muted": "о»Ё пҠ” {format_source}",
    "format-source": "п„° {volume}%",
    "format-source-muted": "п„ұ",
    "format-icons": {
      "headphone": "пҖҘ",
      "hands-free": "пҖҘ",
      "headset": "пҖҘ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№ ",
      "default": [
        "пҖҰ",
        "пҖ§",
        "пҖЁ"
      ]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol"
  },
  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": [
      "оҺҚ",
      "оҸ”",
      "оҸ“",
      "оҸ’",
      "оҸ‘",
      "оҸҗ",
      "оҸҸ",
      "оҸҺ",
      "оҸҚ",
      "оҸҢ",
      "оҸӢ",
      "оҸҠ",
      "оҸү",
      "оҸҲ",
      "оҺӣ"
    ],
    "scroll-step": 1
  },
  "bluetooth": {
    "format-on": "пҠ” On",
    "format-disabled": "пҠ” Off",
    "format-off": "пҠ” Off",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "пҮ« {signalStrength}%",
    "format-ethernet": "у°ҲҖ {ifname}",
    "format-disconnected": "Disconnected",
    "tooltip-format": "у°ҲҖ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "пҮ«  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "у°ҲҖ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/dotfiles/scripts/applications.sh run terminal --class dotfiles-floating -e nmtui"
  },
  "custom/updates": {
    "format": "пӮ« {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/dotfiles/scripts/updates.sh",
    "interval": 3600,
    "on-click": "~/.config/dotfiles/scripts/applications.sh run terminal --class dotfiles-floating -e ~/.config/dotfiles/scripts/install_updates.sh"
  },
  "group/group-power": {
    "orientation": "horizontal",
    "modules": [
      "custom/notification",
      "clock",
      "battery",
      "custom/power"
    ]
  },
  "group/group-hardware": {
    "orientation": "horizontal",
    "modules": [
      "disk",
      "cpu",
      "memory"
    ]
  },
  "group/group-apps": {
    "orientation": "horizontal",
    "modules": [
      "custom/rofi",
      "custom/wallpaper",
      "custom/chromium",
      "custom/filemanager"
    ]
  },
  "group/group-system-status": {
    "orientation": "horizontal",
    "modules": [
      "backlight",
      "pulseaudio",
      "bluetooth",
      "network",
      "custom/updates"
    ]
  }
}
